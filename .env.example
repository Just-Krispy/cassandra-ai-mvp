# Cassandra AI - Environment Configuration
# Copy this file to .env and fill in your values

# Required: Anthropic API Key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Optional: Model Configuration
# Default: claude-sonnet-4-20250514
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: Cost Tracking
# Set to 'true' to enable detailed cost logging
# ENABLE_COST_TRACKING=false

# Optional: Rate Limiting
# Minimum milliseconds between API requests (default: 1000)
# RATE_LIMIT_DELAY_MS=1000

# Optional: Max Tokens
# Maximum tokens for Claude responses (default: 4096)
# MAX_TOKENS=4096

# Optional: Temperature
# Model temperature 0.0-1.0 (default: 0.7)
# TEMPERATURE=0.7
